@{
ViewData["Title"] = "Home Page";
}
<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Tableau de bord</h1>
    <p class="text-sm text-muted-foreground">Vue synthétique de la disponibilité du parc infrastructure.</p>
  </div>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-xl border bg-card p-5 shadow-sm">
      <div class="flex items-center justify-between"><span
          class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Équipements supervisés</span><span
          class="flex h-8 w-8 items-center justify-center rounded-md bg-secondary text-secondary-foreground"><svg
            xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-activity h-4 w-4" aria-hidden="true">
            <path
              d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2">
            </path>
          </svg></span></div>
      <div class="mt-3 text-3xl font-semibold">@ViewBag.Dashboard.TotalMachines</div>
    </div>
    <div class="rounded-xl border bg-card p-5 shadow-sm">
      <div class="flex items-center justify-between"><span
          class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Stables</span><span
          class="flex h-8 w-8 items-center justify-center rounded-md bg-status-stable/15 text-status-stable"><svg
            xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-circle-check h-4 w-4" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m9 12 2 2 4-4"></path>
          </svg></span></div>
      <div class="mt-3 text-3xl font-semibold">@ViewBag.Dashboard.StableMachines</div>
    </div>
    <div class="rounded-xl border bg-card p-5 shadow-sm">
      <div class="flex items-center justify-between"><span
          class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Critiques</span><span
          class="flex h-8 w-8 items-center justify-center rounded-md bg-status-critical/15 text-status-critical"><svg
            xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-triangle-alert h-4 w-4" aria-hidden="true">
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path>
            <path d="M12 9v4"></path>
            <path d="M12 17h.01"></path>
          </svg></span></div>
      <div class="mt-3 text-3xl font-semibold">@ViewBag.Dashboard.CriticalMachines</div>
    </div>
    <div class="rounded-xl border bg-card p-5 shadow-sm">
      <div class="flex items-center justify-between"><span
          class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Rétablis sans doc.</span><span
          class="flex h-8 w-8 items-center justify-center rounded-md bg-status-undocumented/20 text-status-undocumented"><svg
            xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-file-exclamation-point h-4 w-4" aria-hidden="true">
            <path
              d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z">
            </path>
            <path d="M12 9v4"></path>
            <path d="M12 17h.01"></path>
          </svg></span></div>
      <div class="mt-3 text-3xl font-semibold">@ViewBag.Dashboard.UndocumentedMachines</div>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-2"><a href="/etat"
      class="group rounded-xl border bg-card p-6 shadow-sm transition hover:border-primary/50 hover:shadow"><svg
        xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        class="lucide lucide-activity h-6 w-6 text-primary" aria-hidden="true">
        <path
          d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2">
        </path>
      </svg>
      <h3 class="mt-3 font-semibold">État actuel</h3>
      <p class="mt-1 text-sm text-muted-foreground">Visualisez en temps réel l'état des équipements et documentez les
        actions correctives.</p>
    </a><a href="/historique"
      class="group rounded-xl border bg-card p-6 shadow-sm transition hover:border-primary/50 hover:shadow"><svg
        xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        class="lucide lucide-history h-6 w-6 text-primary" aria-hidden="true">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
        <path d="M3 3v5h5"></path>
        <path d="M12 7v5l4 2"></path>
      </svg>
      <h3 class="mt-3 font-semibold">Historique</h3>
      <p class="mt-1 text-sm text-muted-foreground">Consultez les événements passés (4) et leurs résolutions
        documentées.</p>
    </a></div>
  <div class="rounded-xl border bg-card p-5">
    <h3 class="font-semibold">Pistes d'amélioration</h3>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-muted-foreground">
      <li>Notifications temps réel (email / Slack / Teams) sur passage en état critique.</li>
      <li>Polling SNMP / ICMP automatisé via un agent côté serveur.</li>
      <li>SLA &amp; MTTR par équipement et par site.</li>
      <li>Rapports mensuels exportables (PDF/CSV) pour la direction.</li>
      <li>Rôles : Opérateur / Responsable / Auditeur avec permissions distinctes.</li>
    </ul>
  </div>
</div>
